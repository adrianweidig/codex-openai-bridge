# Optional bearer token expected by the bridge.
# Use the same value as the OpenWebUI provider API key.
CODEX_BRIDGE_API_KEY=change-me-local-codex-bridge-key
# Alternative for Docker/Portainer secrets.
# CODEX_BRIDGE_API_KEY_FILE=/run/secrets/codex_bridge_api_key
CODEX_BRIDGE_SECRET_FILE=./secrets/codex_bridge_api_key

# Published host port. Inside the Docker network the service always listens on 4010.
CODEX_BRIDGE_PUBLISHED_PORT=4010

# Existing OpenWebUI Docker network. The current Portainer stack uses ai_net.
OPENWEBUI_DOCKER_NETWORK=ai_net

# Comma-separated model IDs exposed through GET /v1/models.
CODEX_BRIDGE_MODELS=coder,codex,gpt-5.5,gpt-5.4,gpt-5.4-mini,gpt-5.3-codex,gpt-5.3-codex-spark

# Timeout for a single codex exec call in seconds.
CODEX_BRIDGE_TIMEOUT=900

# Seconds between visible streaming progress updates while Codex is still running.
CODEX_BRIDGE_PROGRESS_INTERVAL=15

# Codex sandbox mode. In Docker, set CODEX_BRIDGE_BYPASS_SANDBOX=true only when the container is the sandbox boundary.
CODEX_BRIDGE_SANDBOX_MODE=read-only
CODEX_BRIDGE_BYPASS_SANDBOX=false
